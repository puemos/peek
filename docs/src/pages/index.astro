---
import { Code } from 'astro:components';
import SiteChrome from '../components/SiteChrome.astro';

const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path}`;
const startCommand = `# Start Peek locally
peekd --addr :7700 --data ./data --base-url http://localhost:7700

# Create the first admin from the setup URL in the logs, then log in
peek login --host http://localhost:7700

# Share an HTML file
peek upload demo.html --visibility public

# Inspect follow-up activity
peek list
peek stats <slug>
peek comments <slug>`;
const codeThemes = {
  light: 'github-light',
  dark: 'github-dark',
};
---

<SiteChrome
  title="Peek"
  description="Self-hosted HTML review links for internal teams."
  current="home"
>
  <main class="landing">
    <p class="eyebrow">peek(1)</p>
    <h1>Share HTML reviews inside your company.</h1>
    <p class="lede">
      `Peek` turns generated HTML reports, prototypes, and internal pages into review links with pinned, text-anchored, and page-level feedback. It stays small: one Go server, one CLI, SQLite state, and file or S3-compatible object storage.
    </p>

    <section class="block">
      <h2>Preview</h2>
      <img
        class="hero-image"
        src={href('assets/hero.png')}
        alt="Peek shared-page viewer with an HTML report and in-context comments"
        width="2540"
        height="1520"
      />
    </section>

    <section class="block">
      <h2>Start</h2>
      <Code
        code={startCommand}
        lang="sh"
        themes={codeThemes}
        defaultColor={false}
        class="command-card"
      />
      <div class="actions">
        <a class="button" href={href('docs/')}>read docs</a>
        <a class="button secondary" href={href('manual/')}>manual</a>
      </div>
    </section>
  </main>
</SiteChrome>
