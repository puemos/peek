---
import { getEntry, render } from 'astro:content';
import SiteChrome from '../components/SiteChrome.astro';

const entry = await getEntry('docs', 'manual');

if (!entry) {
  throw new Error('Missing manual content');
}

const { Content } = await render(entry);
---

<SiteChrome
  title={`${entry.data.title} | Peek`}
  description={entry.data.description ?? 'Peek user manual'}
  current="manual"
>
  <main class="docs-layout">
    <aside class="sidebar" aria-label="Manual navigation">
      <a class="sidebar-title" href="#start-here">
        <span>Peek manual</span>
      </a>
      <section class="nav-section">
        <h2>Start</h2>
        <a href="#start-here">Start here</a>
        <a href="#upload-and-share">Upload and share</a>
        <a href="#review-and-comment">Review and comment</a>
      </section>
      <section class="nav-section">
        <h2>Use</h2>
        <a href="#owner-tasks">Owner tasks</a>
        <a href="#admin-tasks">Admin tasks</a>
      </section>
      <section class="nav-section">
        <h2>Run</h2>
        <a href="#operator-tasks">Operator tasks</a>
        <a href="/peek/docs/reference/">Reference</a>
      </section>
    </aside>

    <section class="doc-main">
      <p class="doc-kicker"><span class="prompt">$</span> man peek</p>
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p class="doc-description">{entry.data.description}</p>}
      <article class="doc-article manual-article">
        <Content />
      </article>
    </section>
  </main>
</SiteChrome>
